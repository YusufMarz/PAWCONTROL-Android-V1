<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F3EE">

    <!-- Map Container (sits above Filter Buttons) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/mapContainer"
        android:layout_width="0dp"
        android:layout_height="435dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="0dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/filterContainer">

        <com.mapbox.mapboxsdk.maps.MapView
            android:id="@+id/mapViewInner"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </androidx.cardview.widget.CardView>

    <!-- Filter Buttons Container -->
    <LinearLayout
        android:id="@+id/filterContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="start"
        app:layout_constraintTop_toBottomOf="@+id/mapContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- All Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAll"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="All"
            android:textColor="#D84315"
            android:textSize="14sp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:backgroundTint="#FFE4E1"
            app:cornerRadius="20dp"
            app:icon="@drawable/ic_vet"
            app:iconSize="16dp"
            app:iconGravity="textStart"
            app:strokeWidth="0dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <!-- Vet Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVet"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:text="Vet"
            android:textColor="#666666"
            android:textSize="14sp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:backgroundTint="#FFFFFF"
            app:cornerRadius="20dp"
            app:icon="@drawable/ic_vet"
            app:iconTint="#666666"
            app:iconSize="16dp"
            app:iconGravity="textStart"
            app:strokeColor="#DDDDDD"
            app:strokeWidth="1dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <!-- Shelter Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShelter"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:text="Shelter"
            android:textColor="#666666"
            android:textSize="14sp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:backgroundTint="#FFFFFF"
            app:cornerRadius="20dp"
            app:icon="@drawable/ic_vet"
            app:iconTint="#666666"
            app:iconSize="16dp"
            app:iconGravity="textStart"
            app:strokeColor="#DDDDDD"
            app:strokeWidth="1dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    </LinearLayout>

    <!-- Horizontal RecyclerView for Pet House Cards -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewPetHouses"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:clipToPadding="false"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toBottomOf="@+id/filterContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:listitem="@layout/item_pet_house" />


</androidx.constraintlayout.widget.ConstraintLayout>